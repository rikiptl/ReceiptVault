generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Receipt {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  filePath     String
  mimeType     String
  fileSize     Int      @default(0)

  // Extracted data
  merchant       String?
  date           String?
  total          String?
  subtotal       String?
  tax            String?
  tip            String?
  currency       String   @default("USD")
  category       String?
  ocrText        String?  @db.Text
  items          Json?    @default("[]")
  notes          String?  @db.Text
  confidence     Int?
  paymentMethod  String?
  storePhone     String?

  // Organization
  tags              String[]
  isRecurring       Boolean   @default(false)
  recurringInterval String?
  warrantyExpiry    DateTime?
  reimbursable      Boolean   @default(false)

  // Project/folder
  projectId         String?

  // Return tracking
  returnDeadline    DateTime?
  returnStatus      String?   // "pending" | "completed" | "waived"
  returnNotes       String?   @db.Text

  // Status
  verified     Boolean  @default(false)
  ocrDone      Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([merchant])
  @@index([category])
  @@index([createdAt])
  @@index([isRecurring])
  @@index([reimbursable])
  @@index([returnStatus])
  @@map("receipts")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  color       String   @default("#22c55e")
  icon        String   @default("📁")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Budget {
  id           String   @id @default(uuid())
  category     String   @unique
  monthlyLimit Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("budgets")
}

// Singleton row — always upserted with id="singleton"
model AppSettings {
  id String @id @default("singleton")

  // ── Cloud sync ──────────────────────────────────────────────────────────────
  googleDriveEnabled     Boolean @default(false)
  googleDriveCredentials String  @default("") @db.Text  // service-account JSON
  googleDriveFolderId    String  @default("")

  dropboxEnabled Boolean @default(false)
  dropboxToken   String  @default("")
  dropboxFolder  String  @default("/ReceiptVault")

  // ── Digest ───────────────────────────────────────────────────────────────────
  slackWebhookUrl String @default("")

  resendApiKey  String @default("")
  digestFromEmail String @default("")
  digestToEmail   String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  label     String   @default("")
  secret    String   @default("")
  // comma-separated events: receipt.created,receipt.ocr_completed,receipt.updated
  events    String   @default("receipt.created,receipt.ocr_completed")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

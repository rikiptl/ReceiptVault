generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Receipt {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  filePath     String
  mimeType     String
  fileSize     Int      @default(0)

  // Extracted data
  merchant       String?
  date           String?
  total          String?
  subtotal       String?
  tax            String?
  tip            String?
  currency       String   @default("USD")
  category       String?
  ocrText        String?  @db.Text
  items          Json?    @default("[]")
  notes          String?  @db.Text
  confidence     Int?
  paymentMethod  String?
  storePhone     String?

  // Organization
  tags              String[]
  isRecurring       Boolean   @default(false)
  recurringInterval String?
  warrantyExpiry    DateTime?
  reimbursable      Boolean   @default(false)

  // Return tracking
  returnDeadline    DateTime?
  returnStatus      String?   // "pending" | "completed" | "waived"
  returnNotes       String?   @db.Text

  // Status
  verified     Boolean  @default(false)
  ocrDone      Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([merchant])
  @@index([category])
  @@index([createdAt])
  @@index([isRecurring])
  @@index([reimbursable])
  @@index([returnStatus])
  @@map("receipts")
}

model Budget {
  id           String   @id @default(uuid())
  category     String   @unique
  monthlyLimit Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("budgets")
}

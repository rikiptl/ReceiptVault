# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=receiptvault
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=receiptvault
DATABASE_URL=postgresql://receiptvault:change_me_in_production@postgres:5432/receiptvault

# ── OCR Service ───────────────────────────────────────────────────────────────
# URL of the Tesseract OCR microservice (internal docker network)
OCR_BASE_URL=http://ocr-service:11435/v1
OCR_MODEL=tesseract-ocr

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3500
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Upload path (mapped via Docker volume)
UPLOAD_PATH=/app/uploads
